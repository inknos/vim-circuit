Execute (from_pr warns when unsupported by opencode):
  let g:circuit_provider = 'opencode'
  redir => output
  silent call circuit#from_pr()
  redir END
  Assert output =~# 'from-pr not supported'
  let g:circuit_provider = 'claude'

Execute (from_pr warns when unsupported by gemini):
  let g:circuit_provider = 'gemini'
  redir => output
  silent call circuit#from_pr()
  redir END
  Assert output =~# 'from-pr not supported'
  let g:circuit_provider = 'claude'

Execute (set_mode warns when unsupported by opencode):
  let g:circuit_provider = 'opencode'
  redir => output
  silent call circuit#set_mode('plan')
  redir END
  Assert output =~# 'modes not supported'
  let g:circuit_provider = 'claude'


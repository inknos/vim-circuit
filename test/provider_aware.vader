Execute (worktree warns when unsupported by opencode):
  let g:circuit_provider = 'opencode'
  redir => output
  silent call circuit#worktree('', 0)
  redir END
  Assert output =~# 'worktree not supported'
  let g:circuit_provider = 'claude'

Execute (set_model warns when model_flag is empty):
  " All current providers have model_flag, so test the warning path
  " by verifying claude does NOT warn
  let g:circuit_provider = 'claude'
  redir => output
  " This will try to open a terminal (which fails in test), but should
  " not produce an 'unsupported' warning
  silent! call circuit#set_model('sonnet')
  redir END
  Assert output !~# 'not supported'
  let g:circuit_provider = 'claude'
